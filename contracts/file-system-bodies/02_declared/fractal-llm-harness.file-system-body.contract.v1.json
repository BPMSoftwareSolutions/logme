{
  "schemaVersion": "file-system-body.contract.v1",
  "featureId": "fractal-llm-harness",
  "bodyId": "fractal-llm-harness.recursive-self-testifying-harness-domain",
  "status": "declared",
  "intentNarrative": {
    "plainLanguage": "Fractal LLM Harness lets an LLM propose bounded execution harnesses for its own future work, but only the deterministic substrate can prove a proposal real and promote it.",
    "executionSentence": "Fractal LLM Harness builds an LLM harness-generation assignment, calls the LLM worker, parses and validates the proposed harness, materializes an approved harness into an allowed path, runs and verifies the generated harness against its own body contract, writes a harness receipt, and lets the generated harness propose the next harness without promoting itself."
  },
  "hardLaws": [
    "The LLM may propose a harness; it may never promote one.",
    "No generated harness is real until it testifies with LogMe.",
    "No generated harness may mutate a path outside its declared lease.",
    "No generated harness may claim verification without telemetry.",
    "No generated harness may claim a receipt that was not actually written.",
    "No next-harness proposal may promote without parent-proof."
  ],
  "requiredPaths": {
